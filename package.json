{
  "name": "andesight-rds-toolkit",
  "displayName": "AndeSight RDS Toolkit for VSCode",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:gdbScript.runCurrent",
    "onCommand:gdbScript.startIceman",
    "onCommand:gdbScript.stopIceman"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": [
      {
        "title": "AndeSight RDS Toolkit for VSCode",
        "properties": {
          "gdbScriptRunner.program": {
            "type": "string",
            "default": "./spl/u-boot-spl",
            "description": "Relative path to Program/ELF file used by AndeSight RDS Toolkit for VSCode.",
            "order": 1
          },
          "gdbScriptRunner.debugger": {
            "type": "string",
            "default": "gdb-multiarch",
            "description": "Path to debugger.",
            "order": 2
          }
        }
      },
      {
        "title": "AndeSight RDS Toolkit for VSCode: Andes ICEman",
        "properties": {
          "gdbScriptRunner.iceman.enabled": {
            "type": "boolean",
            "default": false,
            "description": "Start Andes ICEman automatically before running the current GDB script.",
            "order": 1
          },
          "gdbScriptRunner.iceman.andesRoot": {
            "type": "string",
            "default": "C:\\Andestech\\AndeSight_RDS_v511",
            "description": "Root directory of the Andes installation.",
            "order": 2
          },
          "gdbScriptRunner.iceman.executable": {
            "type": "string",
            "default": "${config:gdbScriptRunner.iceman.andesRoot}\\ice\\ICEman.exe",
            "description": "Path to the Andes ICEman executable.",
            "order": 3
          },
          "gdbScriptRunner.iceman.cwd": {
            "type": "string",
            "default": "${config:gdbScriptRunner.iceman.andesRoot}\\ice",
            "description": "Working directory used to start Andes ICEman.",
            "order": 4
          },
          "gdbScriptRunner.iceman.args": {
            "type": "array",
            "default": [
              "--bport=9900",
              "--tport=9901",
              "--port=9902:49151",
              "-Z",
              "v5",
              "--device-usb-combo",
              "002:008:006",
              "-I",
              "gwusb_ftdi_single.cfg"
            ],
            "items": {
              "type": "string"
            },
            "description": "Arguments passed to Andes ICEman.",
            "order": 5
          },
          "gdbScriptRunner.iceman.useAndesEnvironment": {
            "type": "boolean",
            "default": true,
            "description": "Start Andes ICEman in a VS Code terminal using the Cygwin bash environment from the Andes IDE launcher.",
            "order": 6
          },
          "gdbScriptRunner.iceman.startupDelayMs": {
            "type": "number",
            "default": 1000,
            "minimum": 0,
            "description": "Delay before GDB starts after launching Andes ICEman.",
            "order": 7
          }
        }
      }
    ],
    "commands": [
      {
        "command": "gdbScript.runCurrent",
        "title": "Run GDB Script (F5)",
        "icon": "$(debug-start)"
      },
      {
        "command": "gdbScript.startIceman",
        "title": "Start Andes ICEman",
        "icon": "$(debug-start)"
      },
      {
        "command": "gdbScript.stopIceman",
        "title": "Stop Andes ICEman",
        "icon": "$(debug-stop)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "gdbScript.runCurrent",
          "when": "resourceExtname == .gdb",
          "group": "navigation"
        }
      ]
    }
  }
}
